APP_NAME=ProXperty
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Neon PostgreSQL (use direct host for migrations; pooler for production app)
DB_CONNECTION=pgsql
DB_HOST=ep-your-endpoint.region.aws.neon.tech
DB_PORT=5432
DB_DATABASE=sewa_properti
DB_USERNAME=your_neon_user
DB_PASSWORD=your_neon_password
DB_SSLMODE=require
# Required for XAMPP / older libpq (endpoint id = part before -pooler in host)
NEON_ENDPOINT=ep-your-endpoint-id

# Or single connection string from Neon console:
# DATABASE_URL=postgresql://user:password@ep-your-endpoint.region.aws.neon.tech/sewa_properti?sslmode=require

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
